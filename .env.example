# ===== Database =====
# ดีฟอลต์ใช้ SQLite (รันได้ทันที ไม่ต้องตั้งเซิร์ฟเวอร์)
DATABASE_URL="file:./dev.db"

# ===== Auth =====
# ความลับสำหรับเซ็น session cookie — จำเป็นตอน production (ต้องยาว >= 16 ตัว)
# สร้างค่าสุ่ม: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=""

# ===== RDCW Slip Verify (ตรวจสลิปจริง — https://slip.rdcw.co.th/docs) =====
# สร้าง Client ID / Secret จาก dashboard ของ RDCW
RDCW_CLIENT_ID=""
RDCW_CLIENT_SECRET=""

# ===== TrueMoney อั่งเปา (Section 10) =====
# เบอร์ TrueMoney ของร้าน — ห้าม expose ไป client
TRUEMONEY_PHONE="0899999999"

# ===== Discord Webhooks (Section 11) =====
DISCORD_WEBHOOK_TOPUP=""
DISCORD_WEBHOOK_PURCHASE=""

# ===== โหมดจำลอง =====
# true  = ไม่ยิง API จริง (redeem/slip/discord จะถูกจำลอง) — เหมาะกับ demo
# false = ต่อ API จริง (ต้องใส่ RDCW_CLIENT_ID/SECRET และ key อื่นให้ครบ)
MOCK_INTEGRATIONS="true"

# ===== SEO / Google Search Console =====
# URL หลักของเว็บ (ใช้สร้าง sitemap — ตั้งใน Admin > Settings > GSC ก็ได้)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
